<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16.dp">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TITLE -->
            <TextView
                android:id="@+id/edit_log_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:text="@string/edit_log_title"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- edit title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_factors_title"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <CheckBox android:id="@+id/chk_bright_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_brightness" />

                <CheckBox android:id="@+id/chk_strobe_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_strobing" />

                <CheckBox android:id="@+id/chk_other_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_light_manual" />

                <CheckBox android:id="@+id/chk_loud_sound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_loud" />

                <CheckBox android:id="@+id/chk_other_sound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_noise_manual"/>

                <CheckBox android:id="@+id/chk_strong_smell"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_smell_strong" />

                <CheckBox android:id="@+id/chk_other_smell"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_smell_other" />

                <CheckBox android:id="@+id/chk_bad_touch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_touch_texture" />

                <CheckBox android:id="@+id/chk_personal_touch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_personal_space" />

                <CheckBox android:id="@+id/chk_other_touch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_touch_other" />

                <CheckBox android:id="@+id/chk_strong_taste"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_taste_strong" />

                <CheckBox android:id="@+id/chk_bad_taste"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_taste_bad" />

                <CheckBox android:id="@+id/chk_other_taste"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/factor_taste_other" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginVertical="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tags_title"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:layout_marginBottom="8dp" />

            <!-- Empty ChipGroup for tags -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/tags_chip_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp">

                <!-- Tags -->
            </com.google.android.material.chip.ChipGroup>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_log"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:text="@string/save_log_button"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

            <!-- Delete Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_log"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="10dp"
                android:text="@string/delete_log_button"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                app:cornerRadius="16dp" />

            <!-- Bottom padding to ensure scroll content isn't hidden by FAB -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="80dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Hovering "Add Tags" Button -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add_tags"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/add_new_tag_button"
        style="@style/Widget.Material3.FloatingActionButton.Secondary"
        app:icon="@android:drawable/ic_input_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>